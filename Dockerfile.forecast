FROM python:3.11-slim
WORKDIR /app

# Deps layer
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# App files — HTML is served from GCS, not baked into the image.
# This means dashboard updates deploy via gsutil cp, not a Docker rebuild.
COPY forecast_server.py forecast_refresh.py ./

# Cloud Run listens on $PORT (default 8080)
ENV PORT=8080
CMD ["python3", "forecast_server.py"]
