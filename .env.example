# You.com API Key
# Get yours at: https://api.you.com/
YOUCOM_API_KEY=your_youcom_api_key_here

# Anthropic API Key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================
# context.py — Internal System Connectors (all optional)
# Only configure the systems you have access to.
# =============================================================

# --- Salesforce CRM ---
# Your Salesforce login credentials + security token
# Get security token: Salesforce → Settings → Reset My Security Token
SF_USERNAME=your_sf_username@company.com
SF_PASSWORD=your_sf_password
SF_SECURITY_TOKEN=your_sf_security_token
SF_DOMAIN=login

# --- Slack ---
# MUST be a USER token (xoxp-...), NOT a bot token (xoxb-...)
# Bot tokens cannot call search.messages.
# Setup: api.slack.com/apps → Create App → OAuth Scopes: search:read
#        → Install to Workspace → copy "User OAuth Token"
SLACK_USER_TOKEN=xoxp-your-user-token-here

# Bot token — needed for posting messages (digest_run, signals_run, ai_digest_run)
# OAuth Scopes: chat:write
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# =============================================================
# ai_digest_run.py — Daily AI Trends Digest
# =============================================================

# TwitterAPI.io access token
# Sign up at: https://twitterapi.io/
TWITTER_API_KEY=your_twitterapi_io_token_here

# RapidAPI key for "Fresh LinkedIn Scraper" API
# Subscribe at: https://rapidapi.com/freshdata-freshdata-default/api/fresh-linkedin-scraper-api
LINKEDIN_RAPIDAPI_KEY=your_rapidapi_key_here

# SteadyAPI — Reddit search
# Sign up at: https://steadyapi.com/
STEADYAPI_KEY=your_steadyapi_token_here

# Override default Slack channel for AI digest (optional)
# SLACK_CHANNEL_AI_DIGEST=#daily-digest

# --- Gmail + Google Drive ---
# Download credentials.json from Google Cloud Console:
#   console.cloud.google.com → APIs & Services → Credentials
#   → Create OAuth 2.0 Client ID (Desktop app) → Download JSON
# Store the file at the path below. On first run, a browser
# window will open to authorize access. Token is saved automatically.
GOOGLE_CREDENTIALS_FILE=.credentials/google_credentials.json

# Comma-separated Drive file names to exclude from all account lookups.
# Useful for generic/internal files that match on every company search
# (e.g. pricing templates, company-wide decks).
# DRIVE_EXCLUDE_FILES=Factory Pricing Scenarios,Internal Rate Card

# --- Notion ---
# Internal Integration Token from notion.so/my-integrations
# After creating the integration, share relevant pages with it
# via the "Share" button in Notion.
NOTION_API_KEY=secret_your_notion_token_here

# --- Gong API ---
# Generate at: app.gong.io → Company Settings → API (requires technical admin)
# Scope needed: api:calls:read:transcript
GONG_API_KEY=your_gong_api_key_here
GONG_API_SECRET=your_gong_api_secret_here
